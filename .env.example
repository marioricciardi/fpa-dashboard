# Set to false to call live fpa-broker
VITE_USE_MOCK=true

# fpa-broker FastAPI base URL (no trailing slash)
VITE_BROKER_URL=http://localhost:5678

# Broker API key — must match BROKER_API_KEY in fpa_agent/app/.env
# Required when VITE_USE_MOCK=false
VITE_BROKER_API_KEY=local-dev-key-change-in-production

